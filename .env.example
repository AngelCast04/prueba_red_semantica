# Copia este archivo a .env y rellena tu API key:
# cp .env.example .env

# API key de OpenAI (obligatoria para run_consulta.py y run_quickstart.py)
OPENAI_API_KEY=sk-tu-clave-aqui

# Opcional: rutas persistentes para datos del grafo
# GRAPH_WORKING_DIR=./grafo_libros

# Opcional: límite de tareas concurrentes (por defecto 4)
# CONCURRENT_TASK_LIMIT=4

# Opcional: lista CSV de orígenes permitidos para CORS
# Ejemplo:
# CORS_ORIGINS=https://tu-app.onrender.com,https://admin.tudominio.com
# Si no se define, usa "*" (abierto)
# CORS_ORIGINS=*
